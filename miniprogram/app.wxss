/* 结果页 */
.container { padding: 30rpx; background: #f5f5f5; min-height: 100vh; }
.header { text-align: center; margin-bottom: 30rpx; }
.title { font-size: 36rpx; font-weight: bold; color: #333; display: block; }
.subtitle { font-size: 24rpx; color: #999; margin-top: 8rpx; display: block; }
.copy-list { display: flex; flex-direction: column; gap: 20rpx; }
.copy-card { background: #fff; border-radius: 16rpx; overflow: hidden; }
.card-header { display: flex; justify-content: space-between; align-items: center; padding: 20rpx 24rpx; background: #FFF5F7; }
.card-num { font-size: 28rpx; font-weight: bold; color: #FF2442; }
.action-btn { font-size: 24rpx; color: #FF2442; padding: 8rpx 16rpx; }
.card-body { padding: 24rpx; }
.copy-text { font-size: 28rpx; line-height: 1.8; color: #333; white-space: pre-wrap; }
.bottom-bar { display: flex; gap: 20rpx; margin-top: 40rpx; padding-bottom: 40rpx; }
.btn-outline { flex: 1; height: 88rpx; line-height: 88rpx; font-size: 28rpx; background: #fff; color: #FF2442; border: 2rpx solid #FF2442; border-radius: 44rpx; }
.btn-primary { flex: 1; height: 88rpx; line-height: 88rpx; font-size: 28rpx; background: linear-gradient(135deg, #FF2442, #FF6B81); color: #fff; border: none; border-radius: 44rpx; }
.status-footer { text-align: center; font-size: 24rpx; color: #999; margin-top: 20rpx; }

/* 生成中 */
.gen-container { display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 80vh; padding: 60rpx; }
.gen-animation { font-size: 120rpx; margin-bottom: 40rpx; animation: bounce 1s infinite; }
@keyframes bounce { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-20rpx); } }
.progress-bar { width: 80%; height: 8rpx; background: #eee; border-radius: 4rpx; margin: 30rpx 0; overflow: hidden; }
.progress-fill { height: 100%; background: linear-gradient(135deg, #FF2442, #FF6B81); transition: width 0.5s; }
.gen-status { font-size: 28rpx; color: #666; margin-top: 20rpx; }
.gen-error { color: #FF2442; text-align: center; }
.gen-actions { display: flex; gap: 20rpx; margin-top: 40rpx; }

/* 用户页 */
.user-header { display: flex; flex-direction: column; align-items: center; padding: 60rpx 0 30rpx; }
.avatar { font-size: 80rpx; margin-bottom: 16rpx; }
.nickname { font-size: 36rpx; font-weight: bold; color: #333; }
.tier-badge { font-size: 24rpx; padding: 8rpx 24rpx; border-radius: 20rpx; margin-top: 12rpx; }
.tier-badge.free { background: #eee; color: #666; }
.tier-badge.pro { background: linear-gradient(135deg, #FF2442, #FF6B81); color: #fff; }
.stats-card { display: flex; background: #fff; border-radius: 16rpx; padding: 30rpx; margin: 0 30rpx 30rpx; }
.stat { flex: 1; text-align: center; }
.stat-num { font-size: 48rpx; font-weight: bold; color: #FF2442; display: block; }
.stat-label { font-size: 24rpx; color: #999; margin-top: 8rpx; display: block; }
.stat-divider { width: 2rpx; background: #eee; }
.pro-card { margin: 0 30rpx 30rpx; padding: 30rpx; background: #fff; border-radius: 16rpx; }
.pro-card.pro-active { background: #FFF5F7; }
.pro-title { font-size: 32rpx; font-weight: bold; color: #333; display: block; margin-bottom: 16rpx; }
.pro-features { display: flex; flex-direction: column; gap: 12rpx; margin-bottom: 20rpx; font-size: 26rpx; color: #666; }
.pro-price { font-size: 36rpx; font-weight: bold; color: #FF2442; display: block; }
.pro-desc { font-size: 26rpx; color: #666; }
.pro-btn { width: 100%; height: 80rpx; line-height: 80rpx; margin-top: 20rpx; background: linear-gradient(135deg, #FF2442, #FF6B81); color: #fff; font-size: 30rpx; border-radius: 40rpx; border: none; }
.section { margin: 0 30rpx 30rpx; }
.section-title { font-size: 30rpx; font-weight: bold; color: #333; display: block; margin-bottom: 16rpx; }
.empty { text-align: center; padding: 60rpx; color: #999; font-size: 28rpx; }
.empty-hint { font-size: 24rpx; margin-top: 8rpx; display: block; }
